{
  "expo": {
    "name": "KAMA",
    "slug": "kama-gabon",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3D91"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kama.gabon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3D91"
      },
      "package": "com.kama.gabon",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "https://digital-marketplace-186.preview.emergentagent.com/api",
      "eas": {
        "projectId": "kama-gabon"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application a besoin d'accéder à vos photos pour les annonces."
        }
      ]
    ]
  }
}
